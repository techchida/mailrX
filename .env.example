MAILR_DB_HOST=127.0.0.1
MAILR_DB_PORT=3306
MAILR_DB_NAME=mailr
MAILR_DB_USER=root
MAILR_DB_PASS=
MAILR_DB_CHARSET=utf8mb4
MAILR_BASE_URL=http://localhost:8000
MAILR_TRACKING_SECRET=change-me
MAILR_SEND_BATCH_SIZE=50
MAILR_SEND_BATCH_DELAY_MS=150
MAILR_RETRY_MAX_ATTEMPTS=4
MAILR_RETRY_BASE_DELAY_SECONDS=60
MAILR_RETRY_MAX_DELAY_SECONDS=3600
MAILR_SMTP_RATE_LIMIT_PER_MINUTE=0
MAILR_SMTP_RATE_LIMIT_PER_HOUR=0
MAILR_AI_PROVIDER=ollama
MAILR_OLLAMA_URL=http://127.0.0.1:11434
MAILR_OLLAMA_MODEL=llama3.2:3b
MAILR_HF_API_KEY=
MAILR_HF_MODEL=Qwen/Qwen2.5-7B-Instruct
