RewriteEngine On

# Serve existing files/directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all other requests through the root front controller
RewriteRule ^ index.php [L,QSA]

# Block sensitive paths/files when project root is the web root
RewriteRule ^(src|storage|scripts)/ - [F,L]
RewriteRule ^\.env$ - [F,L]
RewriteRule ^\.git - [F,L]
